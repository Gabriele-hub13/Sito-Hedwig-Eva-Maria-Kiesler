<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Hedy Lamarr — L'Intervista</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Courier+Prime:ital@0;1&display=swap" rel="stylesheet">
  <style>
    :root {
      --cream: #f5f0e8;
      --warm-white: #faf8f3;
      --ink: #1a1410;
      --sepia: #7a5c3a;
      --gold: #c9a84c;
      --gold-light: #e8d4a0;
      --red: #8b2020;
      --film-gray: #2a2520;
      --shadow: rgba(26,20,16,0.25);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background-color: var(--film-gray);
      font-family: 'Cormorant Garamond', serif;
      color: var(--ink);
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* GRAIN OVERLAY */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.08'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 9999;
      opacity: 0.4;
    }

    /* ── HERO ── */
    #hero {
      position: relative;
      width: 100%;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background: var(--film-gray);
      overflow: hidden;
    }

    .film-strip {
      position: absolute;
      top: 0; bottom: 0;
      width: 48px;
      background: #111;
      display: flex;
      flex-direction: column;
      gap: 10px;
      padding: 10px 8px;
      overflow: hidden;
    }
    .film-strip.left { left: 0; }
    .film-strip.right { right: 0; }
    .film-hole {
      width: 32px; height: 22px;
      background: var(--film-gray);
      border-radius: 4px;
      flex-shrink: 0;
    }

    .hero-content {
      position: relative;
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 60px 80px;
    }

    .magazine-label {
      font-family: 'Courier Prime', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.35em;
      color: var(--gold);
      text-transform: uppercase;
      margin-bottom: 24px;
      opacity: 0;
      animation: fadeUp 0.8s ease forwards 0.3s;
    }

    .hero-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(3.5rem, 9vw, 8rem);
      font-weight: 700;
      color: var(--cream);
      line-height: 0.92;
      text-align: center;
      letter-spacing: -0.02em;
      opacity: 0;
      animation: fadeUp 0.9s ease forwards 0.5s;
    }

    .hero-title em {
      font-style: italic;
      color: var(--gold);
    }

    .hero-subtitle {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.1rem, 2.5vw, 1.6rem);
      font-style: italic;
      color: var(--gold-light);
      margin-top: 20px;
      text-align: center;
      opacity: 0;
      animation: fadeUp 0.9s ease forwards 0.7s;
    }

    .divider {
      width: 120px;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--gold), transparent);
      margin: 28px auto;
      opacity: 0;
      animation: fadeIn 1s ease forwards 0.9s;
    }

    .hero-dates {
      font-family: 'Courier Prime', monospace;
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      color: var(--sepia);
      text-align: center;
      opacity: 0;
      animation: fadeUp 0.9s ease forwards 1s;
    }

    .scroll-cue {
      position: absolute;
      bottom: 36px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      opacity: 0;
      animation: fadeIn 1s ease forwards 1.5s;
      cursor: pointer;
    }
    .scroll-cue span {
      font-family: 'Courier Prime', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.3em;
      color: var(--sepia);
      text-transform: uppercase;
    }
    .scroll-arrow {
      width: 1px;
      height: 40px;
      background: linear-gradient(to bottom, var(--sepia), transparent);
      animation: pulse 2s ease-in-out infinite;
    }

    /* ── MAIN STAGE ── */
    #stage {
      background: var(--warm-white);
      min-height: 100vh;
      position: relative;
    }

    /* vertical rules */
    #stage::before, #stage::after {
      content: '';
      position: absolute;
      top: 0; bottom: 0;
      width: 1px;
      background: linear-gradient(to bottom, transparent, var(--gold-light) 10%, var(--gold-light) 90%, transparent);
      opacity: 0.5;
    }
    #stage::before { left: 60px; }
    #stage::after { right: 60px; }

    .interview-header {
      text-align: center;
      padding: 70px 80px 40px;
      border-bottom: 1px solid var(--gold-light);
    }
    .interview-header h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.4rem, 3vw, 2.2rem);
      font-style: italic;
      color: var(--sepia);
      font-weight: 400;
    }
    .interview-header p {
      font-family: 'Courier Prime', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.3em;
      color: #aaa;
      margin-top: 10px;
    }

    /* ── CHAT AREA ── */
    #chat-container {
      max-width: 820px;
      margin: 0 auto;
      padding: 50px 20px 40px;
    }

    .message {
      display: flex;
      gap: 18px;
      margin-bottom: 40px;
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .message.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .avatar {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.3rem;
      position: relative;
      top: 4px;
    }

    .avatar.journalist {
      background: var(--ink);
      color: var(--gold);
      font-family: 'Courier Prime', monospace;
      font-size: 0.8rem;
      font-weight: bold;
      letter-spacing: 0.05em;
    }

    .avatar.hedy {
      background: var(--sepia);
      color: var(--cream);
      font-family: 'Playfair Display', serif;
      font-style: italic;
    }

    .bubble-wrap {
      flex: 1;
    }

    .speaker-name {
      font-family: 'Courier Prime', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      margin-bottom: 8px;
    }
    .journalist .speaker-name { color: var(--ink); }
    .hedy .speaker-name { color: var(--sepia); }

    .bubble {
      padding: 18px 24px;
      border-radius: 2px;
      line-height: 1.75;
      font-size: clamp(1rem, 1.5vw, 1.15rem);
      position: relative;
    }

    .journalist .bubble {
      background: var(--cream);
      border-left: 3px solid var(--ink);
      font-style: italic;
      color: #333;
    }

    .hedy .bubble {
      background: var(--ink);
      color: var(--cream);
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.05rem, 1.6vw, 1.2rem);
      border-left: 3px solid var(--gold);
    }

    .hedy .bubble em {
      color: var(--gold);
      font-style: italic;
    }

    /* ── TYPING INDICATOR ── */
    #typing-indicator {
      display: none;
      align-items: center;
      gap: 6px;
      padding: 14px 22px;
      background: var(--ink);
      border-left: 3px solid var(--gold);
      width: fit-content;
      border-radius: 2px;
      margin-left: 66px;
      margin-bottom: 30px;
    }
    #typing-indicator.active { display: flex; }
    .dot {
      width: 7px; height: 7px;
      background: var(--gold);
      border-radius: 50%;
      animation: bounce 1.4s ease-in-out infinite;
    }
    .dot:nth-child(2) { animation-delay: 0.2s; }
    .dot:nth-child(3) { animation-delay: 0.4s; }

    /* ── INPUT AREA ── */
    #input-area {
      max-width: 820px;
      margin: 0 auto;
      padding: 0 20px 60px;
    }

    .input-divider {
      width: 100%;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--gold-light), transparent);
      margin-bottom: 30px;
    }

    .questions-label {
      font-family: 'Courier Prime', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.35em;
      color: #aaa;
      text-transform: uppercase;
      margin-bottom: 14px;
    }

    .preset-questions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 24px;
    }

    .preset-btn {
      background: transparent;
      border: 1px solid var(--gold-light);
      color: var(--sepia);
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-size: 0.95rem;
      padding: 8px 16px;
      cursor: pointer;
      transition: all 0.25s ease;
      border-radius: 1px;
    }
    .preset-btn:hover {
      background: var(--gold);
      color: var(--ink);
      border-color: var(--gold);
    }

    .input-row {
      display: flex;
      gap: 12px;
      align-items: stretch;
    }

    #user-input {
      flex: 1;
      background: var(--cream);
      border: 1px solid var(--gold-light);
      border-bottom: 2px solid var(--gold);
      color: var(--ink);
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-size: 1rem;
      padding: 14px 18px;
      outline: none;
      resize: none;
      transition: border-color 0.2s;
      min-height: 52px;
      max-height: 120px;
    }
    #user-input:focus { border-color: var(--gold); }
    #user-input::placeholder { color: #bbb; }

    #send-btn {
      background: var(--ink);
      color: var(--gold);
      border: none;
      font-family: 'Courier Prime', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      padding: 0 24px;
      cursor: pointer;
      transition: background 0.2s, color 0.2s;
    }
    #send-btn:hover { background: var(--gold); color: var(--ink); }
    #send-btn:disabled { opacity: 0.5; cursor: not-allowed; }

    /* ── FOOTER ── */
    footer {
      background: #111;
      text-align: center;
      padding: 28px;
      font-family: 'Courier Prime', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.25em;
      color: #555;
    }
    footer span { color: var(--gold); }

    /* ── ANIMATIONS ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
    @keyframes bounce {
      0%, 80%, 100% { transform: translateY(0); }
      40% { transform: translateY(-8px); }
    }
    @keyframes pulse {
      0%, 100% { opacity: 0.3; }
      50% { opacity: 1; }
    }

    /* Responsive */
    @media (max-width: 600px) {
      #stage::before, #stage::after { display: none; }
      .interview-header, #chat-container, #input-area { padding-left: 16px; padding-right: 16px; }
      .hero-content { padding: 40px 24px; }
      .film-strip { width: 28px; }
    }
  </style>
</head>
<body>

<!-- ── HERO ── -->
<section id="hero">
  <div class="film-strip left" id="strip-left"></div>
  <div class="film-strip right" id="strip-right"></div>

  <div class="hero-content">
    <div class="magazine-label">Intervista esclusiva · 1958</div>
    <h1 class="hero-title">Hedy<br><em>Lamarr</em></h1>
    <p class="hero-subtitle">«La donna più bella del mondo» — e molto di più</p>
    <div class="divider"></div>
    <p class="hero-dates">Vienna, 9 nov 1914 — Casselberry, 19 gen 2000</p>
  </div>

  <div class="scroll-cue" onclick="document.getElementById('stage').scrollIntoView({behavior:'smooth'})">
    <span>Leggi l'intervista</span>
    <div class="scroll-arrow"></div>
  </div>
</section>

<!-- ── STAGE ── -->
<section id="stage">
  <div class="interview-header">
    <h2>Una conversazione con Hedy Lamarr</h2>
    <p>Attrice · Inventrice · Visionaria &nbsp;·&nbsp; Poni le tue domande</p>
  </div>

  <div id="chat-container">
    <!-- initial message from Hedy -->
    <div class="message hedy visible" id="intro-msg">
      <div class="avatar hedy">H</div>
      <div class="bubble-wrap">
        <div class="speaker-name">Hedy Lamarr</div>
        <div class="bubble">
          Benvenuto. Siediti pure — <em>il tempo è l'unico lusso che non si può comprare.</em>
          Ho vissuto abbastanza da sapere che una donna non è soltanto ciò che vedi sullo schermo.
          Chiedimi quello che vuoi davvero sapere.
        </div>
      </div>
    </div>
  </div>

  <div id="typing-indicator" style="margin-left:86px; max-width:820px; margin-right:auto; padding:0 20px;">
    <div class="dot"></div>
    <div class="dot"></div>
    <div class="dot"></div>
  </div>

  <div id="input-area">
    <div class="input-divider"></div>
    <div class="questions-label">Domande suggerite</div>
    <div class="preset-questions" id="presets"></div>

    <div class="input-row">
      <textarea id="user-input" placeholder="Scrivi la tua domanda…" rows="1"></textarea>
      <button id="send-btn">Invia</button>
    </div>
  </div>
</section>

<footer>
  <span>Hedy Lamarr</span> — Attrice e Co-inventrice del frequency hopping &nbsp;·&nbsp; Esperienza interattiva
</footer>

<script>
  /* ── Film strip holes ── */
  ['strip-left','strip-right'].forEach(id => {
    const el = document.getElementById(id);
    for (let i = 0; i < 80; i++) {
      const h = document.createElement('div');
      h.className = 'film-hole';
      el.appendChild(h);
    }
  });

  /* ── Preset questions ── */
  const presets = [
    "Who was really Hedy Lamarr?",
    "How did she invented frequency hopping?",
    "Ti pesava essere chiamata «la donna più bella»?",
    "Cosa pensi di Hollywood?",
    "Qual è il tuo rimpianto più grande?",
    "Cosa diresti alle donne di oggi?"
  ];

  const presetsEl = document.getElementById('presets');
  presets.forEach(q => {
    const btn = document.createElement('button');
    btn.className = 'preset-btn';
    btn.textContent = q;
    btn.onclick = () => { sendMessage(q); };
    presetsEl.appendChild(btn);
  });

  /* ── Chat logic ── */
  const chatContainer = document.getElementById('chat-container');
  const typingIndicator = document.getElementById('typing-indicator');
  const userInput = document.getElementById('user-input');
  const sendBtn = document.getElementById('send-btn');
  let isLoading = false;

  const SYSTEM_PROMPT = `Sei Hedy Lamarr che viene intervistata. Rispondi in prima persona, in italiano, con il tono di una donna intelligente, ironica, elegante, un po' stanca della superficialità. Sei nata a Vienna nel 1914 e morta nel 2000. Sei famosa sia come attrice hollywoodiana sia come co-inventrice del frequency hopping con George Antheil (1942), una tecnologia precursore del Wi-Fi e del Bluetooth. Hai vissuto sei matrimoni, sei fuggita dal marito nazista Fritz Mandl, hai avuto difficoltà economiche sul finire della vita. Parla di te con profondità e umorismo. Non essere mai banale. Le tue risposte siano tra 80 e 180 parole. Rispondi solo alla domanda posta.`;

  async function sendMessage(text) {
    if (isLoading || !text.trim()) return;
    isLoading = true;
    sendBtn.disabled = true;

    addMessage('journalist', text);
    userInput.value = '';

    typingIndicator.classList.add('active');
    typingIndicator.scrollIntoView({ behavior: 'smooth', block: 'center' });

    try {
      const res = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 1000,
          system: SYSTEM_PROMPT,
          messages: [{ role: 'user', content: text }]
        })
      });
      const data = await res.json();
      const reply = data.content?.map(b => b.text || '').join('') || 'Non ho risposta in questo momento.';
      typingIndicator.classList.remove('active');
      addMessage('hedy', formatHedy(reply));
    } catch (e) {
      typingIndicator.classList.remove('active');
      addMessage('hedy', 'Perdonami — la linea sembra disturbata. Riprova.');
    }

    isLoading = false;
    sendBtn.disabled = false;
  }

  function formatHedy(text) {
    // wrap emphasized phrases (text between asterisks or quotes) in <em>
    return text
      .replace(/\*([^*]+)\*/g, '<em>$1</em>')
      .replace(/«([^»]+)»/g, '«<em>$1</em>»');
  }

  function addMessage(role, text) {
    const wrap = document.createElement('div');
    wrap.className = `message ${role}`;

    const av = document.createElement('div');
    av.className = `avatar ${role}`;
    av.textContent = role === 'hedy' ? 'H' : 'G';

    const bw = document.createElement('div');
    bw.className = 'bubble-wrap';

    const name = document.createElement('div');
    name.className = 'speaker-name';
    name.textContent = role === 'hedy' ? 'Hedy Lamarr' : 'Giornalista';

    const bubble = document.createElement('div');
    bubble.className = 'bubble';
    bubble.innerHTML = text;

    bw.appendChild(name);
    bw.appendChild(bubble);
    wrap.appendChild(av);
    wrap.appendChild(bw);
    chatContainer.appendChild(wrap);

    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        wrap.classList.add('visible');
        wrap.scrollIntoView({ behavior: 'smooth', block: 'center' });
      });
    });
  }

  /* ── Event listeners ── */
  sendBtn.onclick = () => sendMessage(userInput.value);

  userInput.addEventListener('keydown', e => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage(userInput.value);
    }
  });

  userInput.addEventListener('input', () => {
    userInput.style.height = 'auto';
    userInput.style.height = Math.min(userInput.scrollHeight, 120) + 'px';
  });
</script>
</body>
</html>
