<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Hedy Lamarr — The Interview</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Courier+Prime:ital@0;1&display=swap" rel="stylesheet">
  <style>
    :root {
      --cream: #f5f0e8;
      --warm-white: #faf8f3;
      --ink: #1a1410;
      --sepia: #7a5c3a;
      --gold: #c9a84c;
      --gold-light: #e8d4a0;
      --film-gray: #2a2520;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background-color: var(--film-gray);
      font-family: 'Cormorant Garamond', serif;
      color: var(--ink);
      min-height: 100vh;
      overflow-x: hidden;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.08'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 9999;
      opacity: 0.4;
    }

    #hero {
      position: relative;
      width: 100%;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background: var(--film-gray);
      overflow: hidden;
    }

    .film-strip {
      position: absolute;
      top: 0; bottom: 0;
      width: 48px;
      background: #111;
      display: flex;
      flex-direction: column;
      gap: 10px;
      padding: 10px 8px;
      overflow: hidden;
    }
    .film-strip.left { left: 0; }
    .film-strip.right { right: 0; }
    .film-hole {
      width: 32px; height: 22px;
      background: var(--film-gray);
      border-radius: 4px;
      flex-shrink: 0;
    }

    .hero-content {
      position: relative;
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 60px 80px;
    }

    .magazine-label {
      font-family: 'Courier Prime', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.35em;
      color: var(--gold);
      text-transform: uppercase;
      margin-bottom: 24px;
      opacity: 0;
      animation: fadeUp 0.8s ease forwards 0.3s;
    }

    .hero-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(3.5rem, 9vw, 8rem);
      font-weight: 700;
      color: var(--cream);
      line-height: 0.92;
      text-align: center;
      letter-spacing: -0.02em;
      opacity: 0;
      animation: fadeUp 0.9s ease forwards 0.5s;
    }
    .hero-title em { font-style: italic; color: var(--gold); }

    .hero-subtitle {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.1rem, 2.5vw, 1.6rem);
      font-style: italic;
      color: var(--gold-light);
      margin-top: 20px;
      text-align: center;
      opacity: 0;
      animation: fadeUp 0.9s ease forwards 0.7s;
    }

    .divider {
      width: 120px;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--gold), transparent);
      margin: 28px auto;
      opacity: 0;
      animation: fadeIn 1s ease forwards 0.9s;
    }

    .hero-dates {
      font-family: 'Courier Prime', monospace;
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      color: var(--sepia);
      text-align: center;
      opacity: 0;
      animation: fadeUp 0.9s ease forwards 1s;
    }

    .scroll-cue {
      position: absolute;
      bottom: 36px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      opacity: 0;
      animation: fadeIn 1s ease forwards 1.5s;
      cursor: pointer;
    }
    .scroll-cue span {
      font-family: 'Courier Prime', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.3em;
      color: var(--sepia);
      text-transform: uppercase;
    }
    .scroll-arrow {
      width: 1px; height: 40px;
      background: linear-gradient(to bottom, var(--sepia), transparent);
      animation: pulse 2s ease-in-out infinite;
    }

    #stage {
      background: var(--warm-white);
      min-height: 100vh;
      position: relative;
    }
    #stage::before, #stage::after {
      content: '';
      position: absolute;
      top: 0; bottom: 0;
      width: 1px;
      background: linear-gradient(to bottom, transparent, var(--gold-light) 10%, var(--gold-light) 90%, transparent);
      opacity: 0.5;
    }
    #stage::before { left: 60px; }
    #stage::after { right: 60px; }

    .interview-header {
      text-align: center;
      padding: 70px 80px 40px;
      border-bottom: 1px solid var(--gold-light);
    }
    .interview-header h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.4rem, 3vw, 2.2rem);
      font-style: italic;
      color: var(--sepia);
      font-weight: 400;
    }
    .interview-header p {
      font-family: 'Courier Prime', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.3em;
      color: #aaa;
      margin-top: 10px;
    }

    #chat-container {
      max-width: 820px;
      margin: 0 auto;
      padding: 50px 20px 40px;
    }

    .message {
      display: flex;
      gap: 18px;
      margin-bottom: 40px;
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .message.visible { opacity: 1; transform: translateY(0); }

    .avatar {
      width: 48px; height: 48px;
      border-radius: 50%;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      top: 4px;
    }
    .avatar.journalist {
      background: var(--ink);
      color: var(--gold);
      font-family: 'Courier Prime', monospace;
      font-size: 0.8rem;
      font-weight: bold;
      letter-spacing: 0.05em;
    }
    .avatar.hedy {
      background: var(--sepia);
      color: var(--cream);
      font-family: 'Playfair Display', serif;
      font-style: italic;
      font-size: 1.2rem;
    }

    .bubble-wrap { flex: 1; }

    .speaker-name {
      font-family: 'Courier Prime', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      margin-bottom: 8px;
    }
    .journalist .speaker-name { color: var(--ink); }
    .hedy .speaker-name { color: var(--sepia); }

    .bubble {
      padding: 18px 24px;
      border-radius: 2px;
      line-height: 1.75;
      font-size: clamp(1rem, 1.5vw, 1.15rem);
    }
    .journalist .bubble {
      background: var(--cream);
      border-left: 3px solid var(--ink);
      font-style: italic;
      color: #333;
    }
    .hedy .bubble {
      background: var(--ink);
      color: var(--cream);
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.05rem, 1.6vw, 1.2rem);
      border-left: 3px solid var(--gold);
    }
    .hedy .bubble em { color: var(--gold); font-style: italic; }

    #typing-indicator {
      display: none;
      align-items: center;
      gap: 6px;
      padding: 14px 22px;
      background: var(--ink);
      border-left: 3px solid var(--gold);
      width: fit-content;
      border-radius: 2px;
      margin-left: 86px;
      margin-bottom: 30px;
    }
    #typing-indicator.active { display: flex; }
    .dot {
      width: 7px; height: 7px;
      background: var(--gold);
      border-radius: 50%;
      animation: bounce 1.4s ease-in-out infinite;
    }
    .dot:nth-child(2) { animation-delay: 0.2s; }
    .dot:nth-child(3) { animation-delay: 0.4s; }

    #input-area {
      max-width: 820px;
      margin: 0 auto;
      padding: 0 20px 60px;
    }
    .input-divider {
      width: 100%;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--gold-light), transparent);
      margin-bottom: 30px;
    }
    .questions-label {
      font-family: 'Courier Prime', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.35em;
      color: #aaa;
      text-transform: uppercase;
      margin-bottom: 14px;
    }
    .preset-questions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 24px;
    }
    .preset-btn {
      background: transparent;
      border: 1px solid var(--gold-light);
      color: var(--sepia);
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-size: 0.95rem;
      padding: 8px 16px;
      cursor: pointer;
      transition: all 0.25s ease;
      border-radius: 1px;
    }
    .preset-btn:hover { background: var(--gold); color: var(--ink); border-color: var(--gold); }
    .preset-btn:disabled { opacity: 0.4; cursor: not-allowed; }

    .input-row { display: flex; gap: 12px; align-items: stretch; }

    #user-input {
      flex: 1;
      background: var(--cream);
      border: 1px solid var(--gold-light);
      border-bottom: 2px solid var(--gold);
      color: var(--ink);
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-size: 1rem;
      padding: 14px 18px;
      outline: none;
      resize: none;
      transition: border-color 0.2s;
      min-height: 52px;
      max-height: 120px;
    }
    #user-input:focus { border-color: var(--gold); }
    #user-input::placeholder { color: #bbb; }

    #send-btn {
      background: var(--ink);
      color: var(--gold);
      border: none;
      font-family: 'Courier Prime', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      padding: 0 24px;
      cursor: pointer;
      transition: background 0.2s, color 0.2s;
    }
    #send-btn:hover { background: var(--gold); color: var(--ink); }
    #send-btn:disabled { opacity: 0.5; cursor: not-allowed; }

    footer {
      background: #111;
      text-align: center;
      padding: 28px;
      font-family: 'Courier Prime', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.25em;
      color: #555;
    }
    footer span { color: var(--gold); }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
    @keyframes bounce {
      0%, 80%, 100% { transform: translateY(0); }
      40% { transform: translateY(-8px); }
    }
    @keyframes pulse {
      0%, 100% { opacity: 0.3; }
      50% { opacity: 1; }
    }

    @media (max-width: 600px) {
      #stage::before, #stage::after { display: none; }
      .interview-header, #chat-container, #input-area { padding-left: 16px; padding-right: 16px; }
      .hero-content { padding: 40px 24px; }
      .film-strip { width: 28px; }
    }
  </style>
</head>
<body>

<section id="hero">
  <div class="film-strip left" id="strip-left"></div>
  <div class="film-strip right" id="strip-right"></div>
  <div class="hero-content">
    <div class="magazine-label">Exclusive Interview · 1958</div>
    <h1 class="hero-title">Hedy<br><em>Lamarr</em></h1>
    <p class="hero-subtitle">"The most beautiful woman in the world" — and so much more</p>
    <div class="divider"></div>
    <p class="hero-dates">Vienna, Nov 9 1914 — Casselberry, Jan 19 2000</p>
  </div>
  <div class="scroll-cue" onclick="document.getElementById('stage').scrollIntoView({behavior:'smooth'})">
    <span>Read the interview</span>
    <div class="scroll-arrow"></div>
  </div>
</section>

<section id="stage">
  <div class="interview-header">
    <h2>A conversation with Hedy Lamarr</h2>
    <p>Actress · Inventor · Visionary &nbsp;·&nbsp; Ask your questions</p>
  </div>

  <div id="chat-container">
    <div class="message hedy visible">
      <div class="avatar hedy">H</div>
      <div class="bubble-wrap">
        <div class="speaker-name">Hedy Lamarr</div>
        <div class="bubble">
          Please, sit down. <em>Time is the only luxury that cannot be bought.</em>
          I have lived enough to know that a woman is never just what you see on the screen.
          Ask me what you truly want to know.
        </div>
      </div>
    </div>
  </div>

  <div id="typing-indicator">
    <div class="dot"></div><div class="dot"></div><div class="dot"></div>
  </div>

  <div id="input-area">
    <div class="input-divider"></div>
    <div class="questions-label">Suggested questions</div>
    <div class="preset-questions" id="presets"></div>
    <div class="input-row">
      <textarea id="user-input" placeholder="Write your question…" rows="1"></textarea>
      <button id="send-btn">Send</button>
    </div>
  </div>
</section>

<footer>
  <span>Hedy Lamarr</span> — Actress and co-inventor of frequency hopping &nbsp;·&nbsp; Interactive experience
</footer>

<script>
  ['strip-left','strip-right'].forEach(id => {
    const el = document.getElementById(id);
    for (let i = 0; i < 80; i++) {
      const h = document.createElement('div');
      h.className = 'film-hole';
      el.appendChild(h);
    }
  });

  const presets = [
    {
      label: "Who was Hedy Lamarr really?",
      answer: `People knew my face. Very few knew my mind. I was born Hedwig Eva Maria Kiesler in Vienna in 1914 — a curious girl who took apart machines just to see how they worked, long before anyone pointed a camera at me. Hollywood gave me glamour. It also gave me a cage made of silk. I wore it gracefully, but I always knew there was more. *A brain is far more interesting than a face.* I co-invented a radio communication system with George Antheil in 1942 — the patent expired, the Navy ignored it, and I received nothing. Decades later, that same technology became the foundation of Wi-Fi, Bluetooth, and GPS. So who was I really? An inventor who happened to be beautiful. The world preferred it the other way around.`
    },
    {
      label: "The frequency hopping invention",
      answer: `It came from a very unlikely place — dinner conversations with my first husband, Fritz Mandl. He was an arms dealer who sold weapons to Mussolini and Hitler. I sat at those dinners, silent and decorative, while his engineers discussed guided torpedoes and radio-controlled weapons. I listened to *everything*. When I finally escaped him and reached Hollywood, those conversations stayed with me. I met George Antheil at a party. He was a composer obsessed with synchronizing player pianos. I told him about the problem of radio signals — how the enemy could jam a torpedo's guidance frequency. He said: what if the frequency *moved*, jumping in a pattern only the sender and receiver knew? We worked it out on a napkin. In 1942 we received US Patent 2,292,387. The Navy called it impractical. *History proved them wrong.*`
    },
    {
      label: "Being called the most beautiful woman",
      answer: `Louis B. Mayer gave me that title and put it in every press release. He meant it as a compliment. I experienced it as a sentence. *Beauty is a passport, yes — but also a prison.* When you are called the most beautiful woman in the world, no one asks what you think. They ask you to smile. They ask you to stand still. I had ideas — real ideas, technical ideas — and when I tried to share them, men would nod politely and change the subject back to my cheekbones. The cruelest part? I was never taken seriously in my lifetime for the work that mattered most to me. The Pioneer Award came in 1997. I was eighty-two years old. I said to the man on the phone: *It's about time.*`
    },
    {
      label: "Escaping Fritz Mandl",
      answer: `Fritz collected things. Art, weapons, influence — and me. He bought every print of my first film, *Ecstase*, because he found it shameful. He locked me in our estate in Austria. He monitored my letters. He brought me to meetings with Mussolini and Hitler as a beautiful accessory on his arm, while I sat there memorizing everything. One evening I dressed in our maid's uniform and simply walked out. *The most dangerous moment of my life felt strangely calm.* I made it to Paris, then London, then a ship to America. I arrived in Hollywood with nothing but my wits, my face, and everything I had overheard at those terrible dinners. Fritz taught me, without intending to, everything I needed to know about weapons technology. I used that knowledge to help defeat people like him.`
    },
    {
      label: "Hollywood and its limits",
      answer: `Hollywood was magnificent and suffocating in equal measure. It gave me *Samson and Delilah*, it gave me fame, it gave me a contract with MGM that paid me handsomely to be mysterious and still. What it never gave me was the chance to be complex. I once brought a script idea to a producer — a story with real depth. He smiled and said: "Hedy, leave the thinking to us." I smiled back. I went home and worked on my invention instead. *That was the only revenge available to a woman in 1942.* Do I regret Hollywood? No. But I regret what it cost — the years I spent performing beauty instead of building something. The world remembered the films. It forgot the patent until it was too late to matter financially.`
    },
    {
      label: "Your greatest regret",
      answer: `That is a question that deserves honesty rather than grace. My greatest regret is time — specifically, the time I spent waiting for others to recognize my worth instead of insisting upon it. I gave the frequency hopping patent to the United States government freely, in a moment of patriotism during the war. I never received a cent. By the time the technology was used — in military communications, in satellites, in every wireless device on earth — the patent had long expired. *I watched the world go wireless and received nothing for it.* Not bitterness — I understand that I was a woman in a time that had no category for what I was. But if I could speak to my younger self, I would say: *sign nothing without a lawyer, trust your own genius first, and never let anyone reduce you to your reflection.*`
    },
    {
      label: "A message to women today",
      answer: `I would tell them this: *the world will always find a reason to look at your face instead of your ideas.* Do not wait for permission to be intelligent. Do not make yourself smaller so that others feel comfortable. I invented a communication system at my kitchen table in 1942, in between film shoots, while everyone around me assumed I spent my evenings studying my own reflection. I did it because the problem fascinated me — not because anyone encouraged me. Find what fascinates you. Work on it with complete seriousness. And when someone tells you that you are too pretty to be technical, or too emotional to be strategic — *remember my name. Then prove them wrong.*`
    }
  ];

  const fallbacks = [
    `That is a question I have answered in many forms over the years. *The short answer is always simpler than the truth.* What I can tell you is this: I lived two lives simultaneously — one in front of the camera, one inside my own mind. Most people only ever saw the first.`,
    `You ask the right questions. *It is rarer than you think.* I spent decades surrounded by people who asked only about my costumes, my marriages, my beauty routines. A question that requires me to actually think — that is a gift.`,
    `I have thought about this more than you might imagine. Hollywood teaches you to perform certainty even when you have none. But the honest answer is that I am still not entirely sure. *Some questions deserve to remain open.*`,
    `There is a longer version of this story and a shorter one. The shorter one is more flattering to everyone involved. *I have always preferred the longer one.* Every choice I made — even the ones that look like mistakes from the outside — taught me something I needed.`,
    `What strikes me about your question is what it assumes. Most people assume I was passive — that life happened *to* me. I was never passive. *I chose, I acted, I endured, and I invented.* The world simply was not ready to write that version of the story.`
  ];

  let fallbackIndex = 0;

  const presetsEl = document.getElementById('presets');
  presets.forEach(({ label, answer }) => {
    const btn = document.createElement('button');
    btn.className = 'preset-btn';
    btn.textContent = label;
    btn.onclick = () => sendMessage(label, answer);
    presetsEl.appendChild(btn);
  });

  const chatContainer = document.getElementById('chat-container');
  const typingIndicator = document.getElementById('typing-indicator');
  const userInput = document.getElementById('user-input');
  const sendBtn = document.getElementById('send-btn');
  let isLoading = false;

  function getAnswer(question) {
    const q = question.toLowerCase();
    if (q.includes('invent') || q.includes('frequency') || q.includes('wifi') || q.includes('bluetooth') || q.includes('patent') || q.includes('antheil')) return presets[1].answer;
    if (q.includes('beautiful') || q.includes('beauty') || q.includes('pretty') || q.includes('look') || q.includes('appearance')) return presets[2].answer;
    if (q.includes('mandl') || q.includes('escape') || q.includes('flee') || q.includes('husband') || q.includes('marriage') || q.includes('austria')) return presets[3].answer;
    if (q.includes('hollywood') || q.includes('film') || q.includes('movie') || q.includes('actress') || q.includes('mgm') || q.includes('cinema')) return presets[4].answer;
    if (q.includes('regret') || q.includes('mistake') || q.includes('wrong') || q.includes('wish') || q.includes('differently')) return presets[5].answer;
    if (q.includes('women') || q.includes('woman') || q.includes('today') || q.includes('advice') || q.includes('message') || q.includes('young')) return presets[6].answer;
    if (q.includes('who') || q.includes('real') || q.includes('truly') || q.includes('person') || q.includes('identity')) return presets[0].answer;
    const reply = fallbacks[fallbackIndex % fallbacks.length];
    fallbackIndex++;
    return reply;
  }

  function sendMessage(question, directAnswer) {
    if (isLoading || !question.trim()) return;
    isLoading = true;
    sendBtn.disabled = true;
    document.querySelectorAll('.preset-btn').forEach(b => b.disabled = true);

    addMessage('journalist', question);
    userInput.value = '';
    userInput.style.height = 'auto';

    typingIndicator.classList.add('active');
    typingIndicator.scrollIntoView({ behavior: 'smooth', block: 'center' });

    const answer = directAnswer || getAnswer(question);

    setTimeout(() => {
      typingIndicator.classList.remove('active');
      addMessage('hedy', formatHedy(answer));
      isLoading = false;
      sendBtn.disabled = false;
      document.querySelectorAll('.preset-btn').forEach(b => b.disabled = false);
    }, 1400 + Math.random() * 600);
  }

  function formatHedy(text) {
    return text
      .replace(/\*([^*]+)\*/g, '<em>$1</em>')
      .replace(/«([^»]+)»/g, '«<em>$1</em>»');
  }

  function addMessage(role, text) {
    const wrap = document.createElement('div');
    wrap.className = `message ${role}`;
    const av = document.createElement('div');
    av.className = `avatar ${role}`;
    av.textContent = role === 'hedy' ? 'H' : 'G';
    const bw = document.createElement('div');
    bw.className = 'bubble-wrap';
    const name = document.createElement('div');
    name.className = 'speaker-name';
    name.textContent = role === 'hedy' ? 'Hedy Lamarr' : 'Journalist';
    const bubble = document.createElement('div');
    bubble.className = 'bubble';
    bubble.innerHTML = text;
    bw.appendChild(name);
    bw.appendChild(bubble);
    wrap.appendChild(av);
    wrap.appendChild(bw);
    chatContainer.appendChild(wrap);
    requestAnimationFrame(() => requestAnimationFrame(() => {
      wrap.classList.add('visible');
      wrap.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }));
  }

  sendBtn.onclick = () => sendMessage(userInput.value);
  userInput.addEventListener('keydown', e => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(userInput.value); }
  });
  userInput.addEventListener('input', () => {
    userInput.style.height = 'auto';
    userInput.style.height = Math.min(userInput.scrollHeight, 120) + 'px';
  });
</script>
</body>
</html>
